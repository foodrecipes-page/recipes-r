{
  "slug": "refreshing-citrusy-croatian-pineapple-skewers",
  "title": "Grilled Shrimp Skewers with Lemon and Pineapple",
  "description": "A refreshing and citrusy twist on traditional skewers, inspired by Croatian cuisine. This dish is perfect for a quick summer meal or snack.",
  "cuisine": "croatian",
  "diet": [
    "fish",
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Shrimp",
      "amount": "1 pound",
      "notes": "Fresh and deveined"
    },
    {
      "name": "Pineapple chunks",
      "amount": "1 cup",
      "notes": "Fresh and juicy"
    },
    {
      "name": "Lemon wedges",
      "amount": "2-3",
      "notes": "Freshly squeezed for juice"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons",
      "notes": "For brushing skewers"
    },
    {
      "name": "Salt and pepper",
      "amount": "to taste",
      "notes": "For seasoning"
    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "For garnish"
    },
    {
      "name": "Skewers",
      "amount": "10-12",
      "notes": "For grilling"
    },
    {
      "name": "Garlic powder",
      "amount": "1/4 teaspoon",
      "notes": "For flavor"
    }
  ],
  "instructions": [
    {
      "step": "1. Thread shrimp, pineapple, and lemon wedges onto skewers, leaving a little space between each piece."
    },
    {
      "step": "2. Brush skewers with olive oil and season with salt and pepper."
    },
    {
      "step": "3. Preheat grill to medium-high heat."
    },
    {
      "step": "4. Grill skewers for 8-10 minutes, turning occasionally, or until shrimp are pink and cooked through."
    },
    {
      "step": "5. Garnish with fresh parsley and serve immediately."
    },
    {
      "step": "6. Serve with lemon wedges on the side for squeezing over the top."
    },
    {
      "step": "7. Optional: Sprinkle with garlic powder for extra flavor."
    },
    {
      "step": "8. Enjoy your delicious and refreshing grilled shrimp skewers!"
    }
  ],
