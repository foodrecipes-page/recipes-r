{
  "title": "Rich & Creamy Ukrainian Figs Dumplings",
  "description": "A festive whole30-friendly dish featuring rich and creamy dumplings filled with ripe figs, a perfect side for your holiday meal.",
  "cuisine": "Ukrainian",
  "diet": [
    "whole30"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "1 cup almond flour"
    },
    {
      "name": "1/2 cup coconut cream"
    },
    {
      "name": "1/4 cup honey or maple syrup"
    },
    {
      "name": "8 fresh figs, halved and pitted"
    },
    {
      "name": "3 tablespoons butter"
    },
    {
      "name": "1 teaspoon vanilla extract"
    },
    {
      "name": "Pinch of salt"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (200°C).",
    "In a mixing bowl, combine almond flour, coconut cream, honey/maple syrup, and salt. Mix until well combined.",
    "Add in the halved figs, butter, vanilla extract, and mix thoroughly.",
    "Form into small dumplings and place on a baking sheet lined with parchment paper.",
    "Bake for 20-25 minutes or until golden brown and crispy on top.",
    "Serve warm as a dessert or appetizer."
  ],
