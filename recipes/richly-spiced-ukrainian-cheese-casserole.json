{
  "title": "Richly Spiced Ukrainian Cheese Casserole",
  "description": "A cozy Ukrainian dish featuring chili powder and a floral cheese pull, made with ayurvedic-rajasic-friendly ingredients and a nimono-simmer method.",
  "cuisine": "Ukrainian",
  "diet": [
    "vegetarian"
  ],
