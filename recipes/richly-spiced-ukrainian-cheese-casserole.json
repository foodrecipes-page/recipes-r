  "ingredients": [
    {
      "name": "cottage cheese",
      "amount": "1 cup",
      "notes": "large curd"
    },
    {
      "name": "farmers cheese",
      "amount": "1 cup",
      "notes": "crumbly"
    },
    {
      "name": "chili powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "onion powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "eggs",
      "amount": "2 large"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees Fahrenheit.",
    "In a large bowl, combine the cottage cheese, farmers cheese, chili powder, paprika, garlic powder, onion powder, salt, and black pepper.",
    "In a separate bowl, whisk the eggs until they are well beaten.",
    "Add the eggs to the cheese mixture and stir until well combined.",
    "Grease a 9x13 inch baking dish with the butter.",
    "Pour the cheese mixture into the prepared baking dish.",
    "Bake the casserole for 35 minutes, or until it is set and the top is lightly browned.",
    "Remove the casserole from the oven and let it cool for 10 minutes before serving."
  ],
