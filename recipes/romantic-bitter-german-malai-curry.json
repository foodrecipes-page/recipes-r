  "instructions": [
    "Heat the olive oil in a large saucepan over medium heat.",
    "Add the onion and sauté for 5 minutes until translucent.",
    "Add the garlic and sauté for another minute until fragrant.",
    "Add the cashews and sauté for 2 minutes until lightly browned.",
    "Stir in the curry powder, cumin powder, turmeric powder, and cayenne pepper.",
    "Cook for 1 minute until the spices are fragrant.",
    "Add the coconut milk and bring the mixture to a simmer.",
    "Reduce the heat to low and let it cook for 10 minutes.",
    "Stir in the malai paneer and cook for an additional 2 minutes.",
    "Season with salt and black pepper to taste.",
    "Garnish with fresh cilantro leaves and serve hot.",
    "Deglaze the pan with a little water to remove any stuck spices and oils."
  ],
