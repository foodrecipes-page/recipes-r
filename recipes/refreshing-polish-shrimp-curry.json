      "amount": "1 pound",
      "notes": "fresh, peeled, and deveined"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "katsuramuki-cut"
    },
    {
      "name": "Ginger",
      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "Curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "Coconut milk",
      "amount": "1 can"
    },
    {
      "name": "Vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the oil in a large pan over medium heat",
    "Add the grated ginger and cook for 1 minute, until fragrant",
    "Add the katsuramuki-cut onion and cook for 3 minutes, until softened",
    "Add the curry powder and cook for 1 minute, until fragrant",
    "Add the shrimp and cook for 2 minutes, until pink",
    "Add the coconut milk and bring to a simmer",
    "Reduce the heat to low and cook for 5 minutes, until the sauce has thickened",
    "Season with salt and black pepper to taste",
    "Garnish with chopped cilantro and serve over rice"
  ],
