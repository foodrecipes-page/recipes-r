{
  "title": "Rich Velvety Thai Taro Khao Tom",
  "description": "A creamy and comforting Thai dessert made with taro, coconut milk, and dark brown sugar. Enjoy as a warm snack or dessert.",
  "cuisine": "Thai",
  "diet": [
    "vegetarian",
