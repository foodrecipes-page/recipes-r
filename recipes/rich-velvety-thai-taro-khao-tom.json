      "name": "Taro root",
      "amount": "2 large",
      "notes": "peeled and chopped"
    },
    {
      "name": "Coconut milk",
      "amount": "1 can (14 oz)",
      "notes": "full-fat"
    },
    {
      "name": "Dark brown sugar",
      "amount": "1/2 cup",
      "notes": "packed"
    },
    {
      "name": "Water",
      "amount": "2 cups"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Coconut oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Combine taro, coconut milk, brown sugar, water, and salt in a medium saucepan.",
    "Whisk until the sugar dissolves and the mixture comes to a boil.",
    "Reduce heat to medium-low and simmer for 10 minutes or until the taro is tender.",
    "Use an immersion blender to puree the mixture until smooth.",
    "Return the saucepan to the heat and add coconut oil.",
    "Simmer for an additional 2-3 minutes or until the mixture thickens to your liking.",
    "Serve warm or at room temperature."
  ],
