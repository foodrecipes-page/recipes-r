    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "finely chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "canned diced tomatoes",
      "amount": "1 can",
      "notes": "14 oz"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "toasted bread",
      "amount": "1 loaf",
      "notes": "crusty bread"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for 1 minute, until fragrant.",
    "Add the lamb mince and cook, breaking it up with a spoon, until no longer pink, about 5 minutes.",
    "Stir in the cumin and smoked paprika and cook for 1 minute.",
    "Add the diced tomatoes and chicken broth, and bring to a simmer.",
    "Reduce the heat to low and cook, covered, for 20 minutes, stirring occasionally.",
    "Season with salt and pepper to taste.",
    "Serve the tagine over toasted bread.",
    "Garnish with fresh parsley or cilantro, if desired."
  ],
