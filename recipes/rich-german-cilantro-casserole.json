{
  "title": "Rich German Cilantro Casserole",
  "description": "A creamy, garlicky German-inspired casserole packed with cilantro, dashi, and potatoes for a post-workout boost.",
  "cuisine": "German",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "potatoes",
      "amount": "500g",
      "notes": "peeled and sliced"
    },
    {
      "name": "mushrooms",
      "amount": "200g",
      "notes": "sliced"
    },
    {
      "name": "fresh cilantro",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "vegetable dashi",
      "amount": "1 cup",
      "notes": "prepared from dashi powder"
    },
    {
      "name": "cream cheese",
      "amount": "200g",
      "notes": "softened"
    },
    {
      "name": "milk",
      "amount": "1 cup",
      "notes": "whole"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp",
      "notes": "for sautéing"
    },
    {
