    {
      "name": "black pepper",
      "amount": "1/4 tsp",
      "notes": ""
    },
    {
      "name": "Emmental cheese",
      "amount": "50g",
      "notes": "grated"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees F.",
    "In a skillet, heat the olive oil over medium heat and sauté the mushrooms until lightly browned.",
    "Add the sliced potatoes to the skillet and coat them with oregano and thyme, cooking for 5 minutes.",
    "Transfer the potato and mushroom mixture to a baking dish and pour in the prepared vegetable dashi.",
    "Stir in the softened cream cheese and milk until the mixture is creamy and smooth.",
    "Fold in the chopped cilantro and season with salt and pepper.",
    "Top with grated Emmental cheese.",
    "Bake uncovered for 25 minutes, or until the top is golden brown and the casserole is bubbling.",
    "Remove from the oven and let it rest for 5 minutes before serving.",
    "Serve hot and enjoy a protein-packed, creamy German casserole."
  ],
