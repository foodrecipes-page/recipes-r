{
  "title": "Rich Glassy-Jelly Filipino Rest-Meat Oxtail Kare-Kare",
  "description": "A hearty, comforting Filipino dish featuring tender oxtail in a rich, glassy-jelly peanut sauce served over rice. This recipe uses rest-meat oxtail for a delicious and budget-friendly meal prep option.",
  "cuisine": "filipino",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "oxtail (rest-meat)",
      "amount": "2 pounds",
      "notes": "cut into 2-inch pieces"
    },
    {
      "name": "peanuts",
      "amount": "1 cup",
      "notes": "grind into a fine paste"
    },
    {
      "name": "buckwheat flour",
      "amount": "2 tablespoons",
      "notes": "to thicken the sauce"
    },
    {
      "name": "water",
      "amount": "4 cups",
      "notes": "use as the sauce base"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons",
      "notes": "for cooking"
    },
    {
      "name": "frozen green beans",
      "amount": "1 cup",
      "notes": "optional"
    },
    {
      "name": "rice",
      "amount": "2 cups",
      "notes": "cooked according to package instructions"
    }
  ],
  "instructions": [
    "In a large pot, heat the vegetable oil over medium heat.",
    "Add the ground peanuts and cook, stirring constantly, until fragrant and lightly browned about 5 minutes.",
    "Add the buckwheat flour and cook, stirring constantly, for 1 minute.",
    "Gradually add the water, whisking continuously to prevent lumps.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 10 minutes.",
    "Add the oxtail and cook until tender, about 2 hours.",
    "Season the sauce with salt and black pepper to taste.",
    "Serve the oxtail and sauce over cooked rice, garnished with green beans if desired."
  ],
