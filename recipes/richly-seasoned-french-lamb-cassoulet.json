      "name": "lamb shoulder",
      "amount": "1 1/2 pounds",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "dried white beans",
      "amount": "1 cup",
      "notes": "soaked overnight and drained"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "dried thyme",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the tandoor clay pot to 300 degrees Fahrenheit.",
    "Brown the lamb pieces in olive oil over medium high heat, then set aside.",
    "Add the chopped onion to the pot and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the soaked and drained white beans, browned lamb, tomato paste, thyme, paprika, salt, and pepper to the pot.",
    "Stir to combine, then cover the pot with a lid.",
    "Transfer the pot to the preheated tandoor clay pot and cook for 2 1/2 hours.",
    "Remove the pot from the heat and let cool for 10 minutes before serving."
  ],
