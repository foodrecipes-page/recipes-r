      "amount": "1/4 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "4 cups"
    },
    {
      "name": "dried apricots",
      "amount": "1/2 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat.",
    "Add the onion and cook until it is translucent.",
    "Add the garlic and cook for 1 minute.",
    "Add the beef and cook until it is browned.",
    "Add the oats, thyme, salt, and pepper, and stir to combine.",
    "Add the chicken broth and bring to a boil.",
    "Reduce the heat to low and simmer for 30 minutes.",
    "Add the dried apricots and simmer for an additional 10 minutes.",
    "Serve hot, garnished with fresh herbs if desired."
  ],
