{
  "title": "Richly Flavored American Chicken Skillet",
  "description": "A malty, juicy, one-pot American dish featuring tamarind paste, cooked in a stone bowl dolsot for a high-protein friendly meal.",
  "cuisine": "American",
  "diet": [
    "high-protein"
  ],
