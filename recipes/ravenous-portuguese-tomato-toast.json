{
  "title": "Ravenous Portuguese Tomato Toast",
  "description": "A bitter, glassy-jelly midnight craving made with toasted English muffins and sweet-sour confit tomatoes, perfect for an egg‑free snack.",
  "cuisine": "Portuguese",
