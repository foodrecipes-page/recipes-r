      "name": "puff pastry sheet",
      "amount": "1 sheet (200g)",
      "notes": "pre‑rolled lamination pastry"
    },
    {
      "name": "Australian cherry tomatoes",
      "amount": "300g",
      "notes": "halved"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "for brushing"
    },
    {
      "name": "fresh basil leaves",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
