    }
  ],
  "instructions": [
    "Preheat the oven to 200°C (400°F).",
    "In a bowl toss the halved cherry tomatoes with olive oil, salt, pepper, and garlic powder.",
    "Arrange the puff pastry on a baking sheet lined with parchment paper.",
    "Spread the seasoned tomatoes evenly over the pastry, leaving a small border.",
    "Sprinkle the crumbled feta and chopped basil over the tomatoes.",
    "Brush the exposed edges of the pastry with beaten egg.",
    "Bake for 20 minutes until the pastry is golden and the tomatoes are soft.",
    "Cool slightly before slicing into 6 pieces and serving."
  ],
