  "ingredients": [
    {
      "name": "Rye bread",
      "amount": "2 slices"
    },
    {
      "name": "Gouda cheese",
      "amount": "1/4 cup grated"
    },
    {
      "name": "Olive oil",
      "amount": "1-2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "to taste"
    },
    {
      "name": "Pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat the oven to 350°F (175°C).",
    "Place the slices of rye bread on a baking sheet lined with parchment paper.",
    "In a small bowl, mix together olive oil, grated Gouda cheese, salt, and pepper until well combined. Spoon the mixture evenly over each slice of bread.",
    "Bake for about 5-7 minutes or until the cheese is melted and slightly golden on top.",
    "Remove from oven and let cool for a few minutes before serving."
  ],
