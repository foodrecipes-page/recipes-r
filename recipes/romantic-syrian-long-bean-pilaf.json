      "name": "long beans",
      "amount": "1 pound",
      "notes": "trimmed and cut into 1-inch pieces"
    },
    {
      "name": "basmati rice",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large saucepan over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the cumin, paprika, salt, and pepper, and cook for 1 minute, stirring constantly.",
    "Add the long beans and cook until they start to soften, about 5 minutes.",
    "Add the rice and stir to combine with the spice mixture and long beans.",
    "Add the vegetable broth and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 20 minutes, or until the liquid is absorbed and the rice is tender."
  ],
