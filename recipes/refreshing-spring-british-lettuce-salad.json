{
  "title": "Refreshing Spring British Lettuce Salad",
  "description": "A tangy and springy salad featuring British lettuce, fry grind rice, and a citrus vinaigrette, perfect for a light lunch or snack",
  "cuisine": "British",
  "diet": [
    "gluten-free",
    "nut-free",
