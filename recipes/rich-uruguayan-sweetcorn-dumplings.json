{
  "title": "Rich Uruguayan Sweetcorn Dumplings",
  "description": "Buttery and comforting Uruguayan dish featuring sweetcorn, served in an agave leaf vessel, perfect for a cold evening.",
  "cuisine": "Uruguayan",
  "diet": [
    "sugar-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "sweetcorn kernels",
      "amount": "2 cups",
      "notes": "fresh or frozen"
    },
    {
      "name": "all-purpose flour",
      "amount": "1 cup"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "eggs",
      "amount": "2 large"
    },
    {
      "name": "agave leaves",
      "amount": "4 large",
      "notes": "for wrapping dumplings"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together flour, salt, and pepper.",
    "In a separate bowl, whisk together melted butter, eggs, and sweetcorn kernels.",
    "Add the wet ingredients to the dry ingredients and mix until a dough forms.",
    "Divide the dough into 8 equal pieces and shape each into a ball.",
    "Wrap each ball in an agave leaf, making sure to seal the edges.",
    "Place the dumplings in a baking dish and bake for 25 minutes.",
    "Serve warm, garnished with chopped fresh herbs if desired."
  ],
