      "notes": "dissolved in 2 cups water"
    },
    {
      "name": "fry-grind-rice-khao-khua",
      "amount": "1 cup"
    },
    {
      "name": "shiitake mushrooms",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "carrots",
      "amount": "1 cup",
      "notes": "peeled and grated"
    },
    {
      "name": "green onions",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "mirin",
      "amount": "1 tablespoon"
    },
    {
      "name": "eggs",
      "amount": "2",
      "notes": "beaten"
    }
  ],
  "instructions": [
    "Dissolve the vegetable stock cube in 2 cups of water to make the stock",
    "Heat the sesame oil in a pan over medium heat",
    "Add the sliced shiitake mushrooms and cook until they are tender",
    "Add the grated carrots and cook for 2 minutes",
    "Add the chopped green onions and cook for 1 minute",
    "In a separate bowl, whisk together the soy sauce and mirin",
    "Add the fry-grind-rice-khao-khua to the bowl and mix well",
    "Add the beaten eggs to the bowl and mix until just combined",
    "Pour the stock into small cups and add the vegetable and rice mixture",
    "Steam the chawanmushi for 12 minutes or until set"
  ],
