  "instructions": [
    "Heat the olive oil in a clay pot over medium heat.",
    "Add the onions and cook until softened, about 5 minutes.",
    "Add the garlic, ginger, cumin, cinnamon, paprika, salt, and pepper, and cook for 1 minute.",
    "Add the bell peppers and cook until tender, about 10 minutes.",
    "Add the tomatoes, cocoa powder, honey, and chocolate chips, and stir to combine.",
    "Reduce heat to low and simmer, covered, for 20 minutes.",
    "Stir in chopped parsley and pistachios.",
    "Serve over couscous or with bread.",
    "Garnish with additional parsley and pistachios, if desired."
