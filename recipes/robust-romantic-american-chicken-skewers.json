      "amount": "2 tablespoons"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together white vinegar, olive oil, garlic powder, salt, and black pepper.",
    "Add the chicken to the bowl and toss to coat.",
    "Thread the chicken onto skewers, leaving a small space between each piece.",
    "Grill the skewers for 10-12 minutes, turning occasionally.",
    "Garnish with chopped fresh parsley.",
    "Serve hot and enjoy.",
    "Let the skewers rest for a few minutes before serving."
  ],
