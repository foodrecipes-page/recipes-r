  "instructions": [
    "heat the oil in a large pan over medium heat.",
    "add the onion, garlic, and ginger, and cook until the onion is translucent, about 5 minutes.",
    "add the turmeric, cumin, coriander, and cayenne pepper, and cook for 1 minute.",
    "add the fermented soybean paste and cook for 1 minute, stirring constantly.",
    "add the oat flour and cook for 1 minute, stirring constantly.",
    "add the water, treacle, and kale stems, and bring to a boil.",
    "reduce the heat to low and simmer, covered, for 10 minutes.",
    "stir in the kale leaves and cook for 2 minutes, or until wilted.",
    "season with salt to taste.",
    "serve hot."
