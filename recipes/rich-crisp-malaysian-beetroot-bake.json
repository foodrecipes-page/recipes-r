  "instructions": [
    "preheat the oven to 400 degrees fahrenheit",
    "wrap the beetroot in foil and roast for 45 minutes",
    "sauté the onion and garlic in coconut oil until softened",
    "mix the tahini, chili flakes, cumin, salt, and pepper in a bowl",
    "add the roasted beetroot, onion mixture, and coconut milk to the bowl and stir until combined",
    "transfer the mixture to a baking dish and top with chopped cilantro",
    "bake for an additional 20 minutes, or until the top is golden brown"
