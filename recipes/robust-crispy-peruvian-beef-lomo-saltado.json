      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "tomato",
      "amount": "2 medium",
      "notes": "diced"
    },
    {
      "name": "soy sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "vinegar",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large skillet over medium-high heat",
    "Add the beef strips and cook until browned, about 3-4 minutes",
    "Remove the beef from the skillet and set aside",
    "Add the onion and tomato to the skillet and cook until the vegetables are tender",
    "Add the soy sauce, vinegar, garlic, and ginger to the skillet and stir to combine",
    "Return the beef to the skillet and stir to coat with the sauce",
    "Cook for an additional 2-3 minutes, until the beef is cooked through",
    "Season with paprika and serve hot over rice"
  ],
