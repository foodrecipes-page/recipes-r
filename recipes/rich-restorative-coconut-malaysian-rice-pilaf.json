  "instructions": [
    "heat oil in an iron teppan pan over medium heat.",
    "add onion and sauté until translucent.",
    "add ginger and garlic and sauté for 1 minute.",
    "add jasmine rice and stir-fry for 2 minutes.",
    "add coconut milk, pandan leaves, sambal oelek, coconut sugar, fish sauce, salt, and black pepper.",
    "stir-fry for 2 minutes until rice is well coated with the mixture.",
    "reduce heat to low and cover pan with a lid.",
    "cook for 15 minutes or until the liquid has been absorbed and the rice is tender.",
    "remove pandan leaves and fluff the rice with a fork.",
    "serve immediately."
  ],
