{
  "title": "Roasted Ethiopian Baby Aubergine Tagine",
  "description": "A flavorful and nutritious Ethiopian dish featuring roasted baby aubergine, perfect for a post-workout meal or a healthy dinner option.",
  "cuisine": "Ethiopian",
  "diet": [
    "plant-based",
