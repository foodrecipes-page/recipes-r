  "ingredients": [
    {
      "name": "2 tbsp olive oil",
      "amount": "tbsp"
    },
    {
      "name": "1 medium onion, finely chopped",
      "amount": "medium"
    },
    {
      "name": "3 cloves garlic, minced",
      "amount": ""
    },
    {
      "name": "6 oz mushrooms (button or cremini), sliced",
      "amount": "oz"
    },
    {
      "name": "2 tbsp tomato paste",
      "amount": "tbsp"
    },
    {
      "name": "1 cup chicken or vegetable broth",
      "amount": "cup"
    },
    {
      "name": "1/4 cup red wine (optional)",
      "amount": ""
    },
    {
      "name": "2 sprigs fresh thyme, chopped",
      "amount": ""
    },
    {
      "name": "Salt and pepper to taste",
      "amount": ""
    },
    {
      "name": "Fresh parsley for garnish (optional)",
      "amount": ""
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Stir in garlic and cook for another minute until fragrant.",
    "Toss in the mushrooms and sauté until they release their moisture, about 3-4 minutes.",
    "Pour in the tomato paste and stir well to coat the mushrooms evenly.",
    "Add the broth and red wine (if using), bring to a simmer, then reduce by half.",
    "Stir in thyme, salt, and pepper. Taste and adjust seasoning as needed.",
    "Simmer for another 5-7 minutes until the sauce has thickened slightly."
  ],
