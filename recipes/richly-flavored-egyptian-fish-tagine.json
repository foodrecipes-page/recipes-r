  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "Season the fish fillets with salt and black pepper",
    "Heat the olive oil in a large oven-safe skillet over medium heat",
    "Add the chopped onion and cook until softened",
    "Add the minced garlic and grated ginger and cook for 1 minute",
    "Add the tamarind pulp, cumin, and coriander and stir to combine",
    "Add the fish fillets to the skillet and spoon some of the sauce over the top of each fillet",
    "Transfer the skillet to the preheated oven and bake for 12 minutes",
    "Remove the skillet from the oven and serve the fish hot"
  ],
