  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Add the garlic, curry powder, cumin, coriander, and cinnamon, and cook for 1 minute.",
    "Add the pumpkin and cook for 5 minutes, stirring occasionally.",
    "Pour in the coconut milk and bring to a simmer.",
    "Reduce the heat to low and cook, covered, for 20 minutes, or until the pumpkin is tender.",
    "Stir in the chocolate chips until melted and smooth.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with fresh herbs if desired."
