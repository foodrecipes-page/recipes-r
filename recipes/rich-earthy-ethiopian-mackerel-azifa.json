  "ingredients": [
    {
      "name": "canned mackerel",
      "amount": "1 can",
      "notes": "drained and flaked"
    },
    {
      "name": "tempering chocolate",
      "amount": "2 ounces",
      "notes": "melted"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "berbere spice",
      "amount": "1 teaspoon",
      "notes": "Ethiopian spice blend"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons",
      "notes": "for sauteing"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Heat the oil in a large skillet over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and grated ginger and cook for an additional 2 minutes.",
    "Stir in the berbere spice and cook for 1 minute.",
    "Add the flaked mackerel and stir to combine.",
    "Pour in the melted tempering chocolate and stir until well combined.",
    "Season with salt to taste.",
    "Serve the azifa hot, garnished with chopped fresh herbs if desired."
  ],
