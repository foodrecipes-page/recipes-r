{
  "title": "Roasted Gooey Australian Pecorino Bake",
  "description": "Perfect post-workout Australian dish, featuring Pecorino cheese, yuzu-cure and low-glycemic ingredients. Great combination of sweet and savory flavors.",
  "cuisine": "Australian",
  "diet": [
    "low-glycemic",
    "gluten-free"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Pecorino cheese",
      "amount": "250g",
      "notes": ""
    },
    {
      "name": "Australian honey",
      "amount": "2 tbsp",
      "notes": ""
    },
    {
      "name": "Yuzu juice",
      "amount": "2 tbsp",
      "notes": "Yuzu cure, 1:1 yuzu juice:water"
    },
    {
      "name": "Yuzu zest",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "Gluten-free oats",
      "amount": "100g",
      "notes": ""
    },
    {
      "name": "Unsalted butter",
      "amount": "50g",
      "notes": ""
    },
    {
      "name": "Coconut oil",
      "amount": "25g",
      "notes": "For greasing the baking dish"
    },
    {
      "name": "Eggs",
      "amount": "2",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat oven to 180°C (350°F).",
    "Grease a 20cm (8 inch) square baking dish with coconut oil.",
    "In a large bowl, combine Pecorino cheese, Australian honey, Yuzu juice, and Yuzu zest. Mix well to combine.",
    "Add gluten-free oats and mix until a crumbly mixture forms.",
    "In a separate bowl, whisk together eggs and Unsalted butter. Add to the Pecorino mixture and mix until just combined.",
    "Pour the mixture into the prepared baking dish and smooth the top.",
    "Bake for 25 minutes or until the edges are golden brown and the center is still slightly jiggly.",
    "Remove from oven and let cool for 5 minutes before serving."
  ],
