    },
    {
      "name": "1/2 cup red wine",
      "amount": "",
      "notes": "optional"
    },
    {
      "name": "1 large red bell pepper",
      "amount": "diced",
      "notes": ""
    }
  ],
  "instructions": [
    "preheat oven to 375 degrees F",
    "season the beef with mixed spice blend, cumin, paprika, and black pepper",
    "heat the oil in a large clay pot over medium-high heat",
    "sauté the beef until browned, about 5 minutes",
    "add the onion, garlic, and red bell pepper to the pot and cook until the onion is translucent",
    "add the wine to the pot and bring to a simmer",
    "transfer the pot to the preheated oven and roast for 1 hour",
    "cover the pot and continue cooking for an additional 30 minutes",
    "remove the pot from the oven and let rest for 10 minutes before serving"
