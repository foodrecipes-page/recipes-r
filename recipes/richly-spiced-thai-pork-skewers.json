{
  "title": "Richly Spiced Thai Pork Skewers",
  "description": "Pungent and silky Thai dish featuring cocoa powder and lamination-puff, this recipe brings an adventurous twist to traditional Thai cuisine, with a kosher-friendly approach.",
  "cuisine": "Thai",
  "diet": [
    "kosher"
  ],
