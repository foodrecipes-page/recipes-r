{
  "title": "Roasted Mediterranean Chinese Long Beans Gratin",
  "description": "A Mediterranean-inspired dish featuring roasted Chinese long beans, pickles, and a flavorful topping. This dish is kid-friendly and Whole30-friendly.",
  "cuisine": "Mediterranean",
  "diet": [
