      "amount": "1/2 teaspoon"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the onion and cook until it is translucent.",
    "Add the garlic and ginger and cook for 1 minute.",
    "Add the chicken and cook until it is browned on all sides.",
    "Add the curry powder and khus khus and cook for 1 minute.",
    "Add the coconut milk and bring to a simmer.",
    "Reduce the heat to low and cook for 20 minutes or until the chicken is cooked through.",
    "Season with salt and pepper to taste.",
    "Serve hot over rice or noodles."
