  "instructions": [
    "heat 2 tablespoons olive oil in a large skillet over medium-high heat.",
    "sauté the beef until browned, about 5 minutes.",
    "remove the beef from the skillet and set aside.",
    "reduce heat to medium-low and add the beurre-monte, stir until melted.",
    "add the chopped green onions, parsley, garlic, ginger, paprika, salt, and black pepper to the skillet and stir to combine.",
    "add the beef back to the skillet and stir to coat with the spices.",
    "add the beef stock to the skillet and bring to a simmer.",
    "cook until the beef is tender, about 1 hour and 15 minutes.",
    "taste and adjust seasoning as needed."
