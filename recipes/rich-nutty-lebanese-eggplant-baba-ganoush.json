{
  "title": "Rich Nutty Lebanese Eggplant Baba Ganoush",
  "description": "A dense, nutty dip infused with unsweetened coconut milk and a bright yuzu cure, perfect for low-glycemic snacking.",
  "cuisine": "Lebanese",
  "diet": [
    "low-glycemic",
    "gluten-free"
  ],
