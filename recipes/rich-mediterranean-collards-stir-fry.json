  "ingredients": [
    {
      "name": "400g (14oz) collards",
      "amount": "packed leaves",
      "notes": "Washed and chopped"
    },
    {
      "name": "2 tbsp olive oil"
    },
    {
      "name": "3 cloves garlic, minced"
    },
    {
      "name": "1 cup sundried tomatoes, diced"
    },
    {
      "name": "1/4 cup fresh parsley, finely chopped"
    },
    {
      "name": "1/4 cup fresh mint, finely chopped"
    },
    {
      "name": "2 tbsp capers, drained and rinsed"
    },
    {
      "name": "1/4 cup crumbled feta cheese"
    },
    {
      "name": "Juice of 1 lemon"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium heat.",
    "Add minced garlic and cook for about 1 minute until fragrant.",
    "Add chopped collards, sundried tomatoes, parsley, mint, capers, feta cheese, and juice of lemon. Stir well to combine all ingredients.",
    "Stir occasionally for about 5-7 minutes or until the leaves are wilted but still slightly firm and sauce is thickened.",
    "Season with salt and pepper to taste."
  ],
