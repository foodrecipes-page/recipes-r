{
  "title": "Robust Spicy Korean Lamb Skewers",
  "description": "A winey and fluffy Mediterranean dish featuring gochugaru, with a nostalgic twist, served in an agave leaf vessel.",
  "cuisine": "Korean",
  "diet": [
    "high-protein"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "gochugaru",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "agave leaves",
      "amount": "4",
      "notes": "for serving"
    }
  ],
  "instructions": [
    "Preheat grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together gochugaru, soy sauce, brown sugar, garlic, and ginger.",
    "Add the lamb cubes to the bowl and toss to coat with the marinade.",
    "Thread the marinated lamb cubes onto skewers, leaving a small space between each piece.",
    "Brush the skewers with sesame oil.",
    "Grill the skewers for 10 minutes, turning occasionally.",
    "Serve the skewers in agave leaves, garnished with additional gochugaru if desired.",
    "Let the skewers rest for 5 minutes before serving."
  ],
