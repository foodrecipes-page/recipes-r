  "ingredients": [
    {
      "name": "toor dal",
      "amount": "250g"
    },
    {
      "name": "cloves",
      "amount": "2 tsp, ground"
    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "ginger",
      "amount": "1 tsp, grated"
    },
    {
      "name": "tumeric",
      "amount": "1 tsp, ground"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "butter",
      "amount": "2 tbsp"
    },
    {
      "name": "fenugreek seeds",
      "amount": "1 tsp"
    },
    {
      "name": "chopped cilantro",
      "amount": "for garnish"
    },
    {
      "name": "lemon juice",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Heat oil in a molcajete over medium heat. Add onion and cook until translucent.",
    "Add ginger, tumeric, salt, and ground cloves. Cook for 1 minute, stirring constantly.",
    "Add toor dal and 250ml water. Bring to a boil, then reduce heat and simmer for 20 minutes.",
    "Add butter and fenugreek seeds. Stir until butter is melted and seeds are fragrant.",
    "Deglaze the molcajete with lemon juice. Scrape up any browned bits from the bottom.",
    "Garnish with chopped cilantro. Serve hot."
  ],
