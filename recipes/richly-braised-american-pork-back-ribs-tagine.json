    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon",
      "notes": "ground"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon",
      "notes": "smoked"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "In a large Dutch oven or tagine, heat the olive oil over medium heat.",
    "Add the grated ginger and cook for 1 minute, stirring constantly.",
    "Add the pork back ribs and brown them on all sides, about 5 minutes.",
    "Add the lemon juice, honey, prunes, chicken broth, tomato paste, cumin, and paprika, stirring to combine.",
    "Cover the pot and transfer it to the preheated oven.",
    "Braise the ribs for 2 1/2 hours, or until the meat is tender and falls off the bone.",
    "Remove the pot from the oven and let it cool slightly.",
    "Serve the ribs with the rich and velvety sauce spooned over the top."
  ],
