    },
    {
      "name": "Eggs",
      "amount": "2 large",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat the oven to 375F (190C).",
    "In a large mixing bowl, whisk together the flour, baking powder, cinnamon, cardamom, and salt.",
    "In a separate bowl, mix together the stroop, sugar, and melted butter until well combined.",
    "Add the yogurt and mix until smooth.",
    "Add the eggs and mix until well combined.",
    "Gradually add the dry ingredients to the wet ingredients, mixing until a sticky dough forms.",
    "Spoon the dough into a greased 9x13 inch baking dish.",
    "Bake for 25-30 minutes or until golden brown.",
    "Let cool for a few minutes before serving."
  ],
