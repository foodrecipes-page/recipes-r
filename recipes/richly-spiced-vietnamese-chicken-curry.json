  "ingredients": [
    {
      "name": "boneless chicken thighs",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 1/2 inch pieces"
    },
    {
      "name": "ghee",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "curry powder",
      "amount": "2 teaspoons"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "coconut milk",
      "amount": "1 can",
      "notes": "14 ounces"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the ghee in a large saucepan over medium heat",
    "Add the onion and cook until softened, about 5 minutes",
    "Add the garlic and ginger and cook for 1 minute",
    "Add the curry powder, cumin, and cayenne pepper and cook for 1 minute",
    "Add the chicken and cook until browned, about 5 minutes",
    "Add the coconut milk, fish sauce, and lime juice and bring to a simmer",
    "Reduce the heat to low and cook, covered, until the chicken is cooked through, about 15 minutes",
    "Serve the curry hot, garnished with chopped cilantro and lime wedges"
  ],
