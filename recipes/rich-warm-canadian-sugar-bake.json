{
  "title": "maple sugar oatmeal bake",
  "description": "a warm, comforting, and comforting breakfast dish featuring the sweetness of maple syrup and the earthiness of oats.",
  "cuisine": "canadian",
  "diet": [
    "gluten-free"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "rolled oats",
      "amount": "2 cups",
      "notes": "gluten-free oats"
    },
    {
      "name": "granulated sugar",
      "amount": "1/2 cup",
      "notes": "vegan-friendly"
    },
    {
      "name": "maple syrup",
      "amount": "1/4 cup"
    },
    {
      "name": "non-dairy milk",
      "amount": "1 cup",
      "notes": "such as almond or soy milk"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "cinnamon",
      "amount": "1/4 tsp"
    },
    {
      "name": "nutmeg",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "preheat the oven to 375 fahrenheit.",
    "in a large bowl, combine the oats, sugar, and spices.",
    "in a separate bowl, whisk together the non-dairy milk and vanilla extract.",
    "pour the wet ingredients over the dry ingredients and stir until well combined.",
    "transfer the mixture to a 9x9 inch baking dish.",
    "bake for 35-40 minutes, or until the top is golden brown and the oats are tender.",
    "remove from the oven and let cool for a few minutes.",
    "serve warm, topped with additional maple syrup and non-dairy milk if desired."
  ],
