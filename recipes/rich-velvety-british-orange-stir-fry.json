  "ingredients": [
    {
      "name": "Candied Orange Peel",
      "amount": "1 cup",
      "notes": "Dried orange peel, candied"
    },
    {
      "name": "Chickpeas",
      "amount": "1 can (15 oz)",
      "notes": ""
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": ""
    },
    {
      "name": "Garlic",
      "amount": "2 cloves",
      "notes": ""
    },
    {
      "name": "Red Pepper Flakes",
      "amount": "1/4 tsp",
      "notes": ""
    },
    {
      "name": "Olive Oil",
      "amount": "2 tbsp",
      "notes": ""
    },
    {
      "name": "Juice of 3 Oranges",
      "amount": "1 cup",
      "notes": ""
    },
    {
      "name": "Salt",
      "amount": "To taste",
      "notes": ""
    }
  ],
  "instructions": [
    "Heat olive oil in a large pan over medium heat.",
    "Add onions and red pepper flakes, sauté until soft, about 5 minutes.",
    "Chop the garlic finely and add it to the pan. Sauté for another minute.",
    "Add the candied orange peel to the pan with 1/4 cup of the juice from oranges. Stir gently to combine.",
    "Pour in the remaining juice and bring to a simmer.",
    "Stir in chickpeas, reduce heat, and let cook until the liquid is absorbed (about 5 minutes).",
    "Season with salt to taste.",
    "Garnish with extra orange zest if desired."
  ],
