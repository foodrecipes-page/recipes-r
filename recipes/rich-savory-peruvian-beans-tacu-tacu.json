      "notes": "soaked overnight"
    },
    {
      "name": "whole black peppercorns",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "rendered fat",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "rice",
      "amount": "2 cups",
      "notes": "cooked"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the rendered fat in a large skillet over medium heat",
    "Add the chopped onion and cook until it is translucent",
    "Add the minced garlic and cook for an additional minute",
    "Add the soaked and drained black beans, whole black peppercorns, and salt to the skillet",
    "Cook for 10 minutes, stirring occasionally, until the beans are tender",
    "Stir in the cooked rice and cook for an additional 2 minutes",
    "Taste and adjust the seasoning as needed",
    "Transfer the mixture to a plate and shape into a tacu tacu",
    "Garnish with chopped scallions and serve immediately"
  ],
