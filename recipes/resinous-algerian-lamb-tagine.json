{
  "title": "Resinous Algerian Lamb Tagine",
  "description": "A hearty, one-pot dish from Algeria, featuring lamb in a rich, resinous sauce infused with peach juice and yuzu-cure.",
  "cuisine": "Algerian",
  "diet": [
    "Gluten-free",
