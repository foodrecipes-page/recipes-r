  "ingredients": [
    {
      "name": "plain chocolate",
      "amount": "200g",
      "notes": "dairy-free"
    },
    {
      "name": "shio-koji cure",
      "amount": "20g"
    },
    {
      "name": "oat flour",
      "amount": "100g"
    },
    {
      "name": "coconut sugar",
      "amount": "50g"
    },
    {
      "name": "coconut oil",
      "amount": "25g"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "sea salt",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 180 degrees Celsius.",
    "Mix together the oat flour, coconut sugar, and sea salt in a bowl.",
    "Add the shio-koji cure and mix until well combined.",
    "Melt the plain chocolate in a double boiler.",
    "Add the coconut oil and vanilla extract to the melted chocolate and stir until smooth.",
    "Combine the dry ingredients with the chocolate mixture and stir until a dough forms.",
    "Press the dough into a lined baking dish.",
    "Refrigerate for at least 30 minutes to set.",
    "Cut into bars and serve."
  ],
