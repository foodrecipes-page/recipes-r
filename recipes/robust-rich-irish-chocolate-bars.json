{
  "title": "Robust Rich Irish Chocolate Bars",
  "description": "A tangy and crisp Irish dessert featuring plain chocolate and shio-koji cure, made satvik-friendly by using non-animal derived ingredients.",
  "cuisine": "Irish",
  "diet": [
    "satvik",
    "vegetarian"
  ],
