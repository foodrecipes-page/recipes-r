{
  "title": "Roasted American Broccoli Bake",
  "description": "Umami-rich, crisp American dish featuring broccoli, fermented jang, and ayurvedic-tamasic-friendly ingredients.",
  "cuisine": "American",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "broccoli",
      "amount": "3 bunches",
      "notes": "trims, crowns intact"
    },
    {
      "name": "fermented jang",
      "amount": "2 tbsp",
      "notes": "spicy Korean chili paste"
    },
    {
      "name": "brown rice flour",
      "amount": "1 cup",
      "notes": ""
    },
    {
      "name": "unsalted butter",
      "amount": "4 tbsp",
      "notes": "melted"
    },
    {
      "name": "garlic",
      "amount": "4 cloves",
      "notes": "minced"
    },
    {
      "name": "nutritional yeast",
      "amount": "2 tbsp",
      "notes": "sprinkle"
    },
    {
      "name": "salt",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "black pepper",
      "amount": "1 tsp",
      "notes": ""
    },
    {
