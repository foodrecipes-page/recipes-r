  "instructions": [
    "heat oil in a pan over medium-high heat.",
    "add onion and sauté for 3 minutes.",
    "add crushed tomatoes, red pepper, cumin, smoked paprika, salt, and black pepper. stir and bring to a simmer.",
    "add fry grind rice and stir to combine.",
    "add tomato ketchup and stir to coat.",
    "reduce heat to medium-low and cook for 5 minutes.",
