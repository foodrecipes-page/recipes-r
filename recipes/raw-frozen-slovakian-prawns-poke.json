      "name": "Raw Frozen Prawns",
      "amount": "12 ounces",
      "notes": "Thawed according to package instructions."
    },
    {
      "name": "Fresh Cilantro",
      "amount": "1/4 cup",
      "notes": "Chopped."
    },
    {
      "name": "Green Onions",
      "amount": "1/4 cup",
      "notes": "Thinly sliced."
    },
    {
      "name": "Grapefruit Juice",
      "amount": "2 tablespoons",
      "notes": "Freshly squeezed."
    },
    {
