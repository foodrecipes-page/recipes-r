  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into small pieces"
    },
    {
      "name": "tomato ketchup",
      "amount": "1/2 cup"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "vegetable oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "Thai red curry paste",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "white bread",
      "amount": "4 slices"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large skillet over medium-high heat.",
    "Add the chicken to the skillet and cook until browned and cooked through.",
    "In a small bowl, whisk together the tomato ketchup, fish sauce, lime juice, and Thai red curry paste.",
    "Pour the ketchup mixture over the cooked chicken and stir to combine.",
    "Season the chicken with salt and black pepper to taste.",
    "Toast the white bread until lightly browned.",
    "Spoon the chicken mixture over the toasted bread.",
    "Garnish with chopped fresh cilantro.",
    "Serve immediately and enjoy."
  ],
