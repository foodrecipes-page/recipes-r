{
  "title": "Richly Garlicky French Khus Khus Madeleine",
  "description": "A low-carb, garlicky, crumbly French madeleine featuring khus khus and ferment-kimchi, perfect for midnight cravings.",
  "cuisine": "French",
  "diet": [
    "low-carb",
    "gluten-free"
  ],
