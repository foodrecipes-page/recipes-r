      "name": "papelon",
      "amount": "1 cup",
      "notes": "diced"
    },
    {
      "name": "fish fillets",
      "amount": "4 fillets",
      "notes": "any white fish"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "peppercorns",
      "amount": "1 teaspoon",
      "notes": "black"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "water",
      "amount": "4 cups"
    },
    {
      "name": "namul",
      "amount": "1 cup",
      "notes": "blanched and seasoned"
    }
  ],
  "instructions": [
    "Heat the oil in the Dutch oven over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the papelon, fish fillets, peppercorns, and salt, and stir to combine.",
    "Pour in the water and bring the mixture to a boil.",
    "Reduce the heat to low and simmer for 20 minutes.",
    "Add the namul and stir to combine.",
    "Continue to simmer for an additional 10 minutes or until the fish is cooked through.",
    "Serve hot and enjoy."
  ],
