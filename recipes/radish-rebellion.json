      "amount": "1 cup thinly sliced"
    },
    {
      "name": "Vinegar",
      "amount": "1/2 cup apple cider vinegar"
    },
    {
      "name": "Salt",
      "amount": "1 tsp"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "Parsley",
      "amount": "2 tbsp chopped fresh parsley"
    },
    {
      "name": "Eggs",
      "amount": "4 eggs, beaten"
    },
    {
      "name": "Butter",
      "amount": "2 tbsp melted butter"
    }
  ],
  "instructions": [
    "Mix radish slices with vinegar and salt. Let stand for 1 hour.",
    "Sauté garlic in butter until fragrant, then add parsley and cook for another minute.",
    "Fold egg mixture into radish mixture gently but thoroughly.",
    "Pour the radish mixture onto a baking dish lined with parchment paper.",
    "Bake at 350°F (175°C) for 20-25 minutes until golden brown on top.",
    "Serve warm or at room temperature."
