  "ingredients": [
    {
      "name": "prunes",
      "amount": "1 cup",
      "notes": "pitted"
    },
    {
      "name": "beef brisket",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the beef brisket and cook until browned on all sides, about 5 minutes.",
    "Add the prunes, paprika, salt, and black pepper, and stir to combine.",
    "Pour in the chicken broth and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 2 hours, or until the meat is tender.",
    "Serve the stew hot, garnished with fresh herbs if desired."
  ],
