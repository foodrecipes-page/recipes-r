  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "pecan nuts",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "coconut milk",
      "amount": "1/4 cup"
    },
    {
      "name": "black pepper",
      "amount": "2 teaspoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "ginger",
      "amount": "2 tablespoons",
      "notes": "grated"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit",
    "In a large bowl, whisk together coconut milk, black pepper, salt, ginger, and garlic",
    "Add the chicken to the bowl and marinate for 30 minutes",
    "Thread the marinated chicken onto skewers, leaving a small space between each piece",
    "Brush the skewers with olive oil and sprinkle with chopped pecan nuts",
    "Grill the skewers for 10-12 minutes, or until the chicken is cooked through",
    "Steam the skewers using mushimono-steam method for an additional 2 minutes",
    "Serve hot and enjoy"
  ],
