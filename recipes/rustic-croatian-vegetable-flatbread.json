{
  "title": "Rustic Croatian Vegetable Flatbread",
  "description": "A yeasty and crunchy flatbread featuring a variety of vegetables, perfect for a quick and satisfying meal.",
  "cuisine": "Croatian",
  "diet": [
    "vegetarian"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "all purpose flour",
      "amount": "2 cups",
      "notes": "preferably unbleached"
    },
    {
      "name": "active dry yeast",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "zucchini",
      "amount": "1 medium",
      "notes": "sliced"
    },
    {
      "name": "bell pepper",
      "amount": "1 medium",
      "notes": "sliced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "feta cheese",
      "amount": "1/2 cup",
      "notes": "crumbly"
    }
  ],
  "instructions": [
    "In a large mixing bowl, combine flour, yeast, and salt.",
    "Gradually add olive oil and mix until a dough forms.",
    "Knead the dough for 5 minutes until it becomes smooth and elastic.",
    "Let the dough rise in a warm place for 30 minutes.",
    "Preheat the oven to 425 degrees.",
    "Roll out the dough into a thin circle, about 1/4 inch thick.",
    "Arrange the sliced zucchini, bell pepper, and onion on one half of the dough.",
    "Sprinkle crumbly feta cheese over the vegetables.",
    "Fold the other half of the dough over the filling to form a half moon shape.",
    "Bake the flatbread for 20 minutes or until golden brown."
  ],
