    {
      "name": "1 teaspoon ground cumin",
      "amount": "tsp"
    },
    {
      "name": "1/2 teaspoon smoked paprika",
      "amount": "tsp"
    },
    {
      "name": "pinch of salt",
      "amount": ""
    },
    {
      "name": "1/4 cup Sriracha sauce",
      "amount": ""
    },
    {
      "name": "3 cups water or vegetable broth",
      "amount": "cup"
    },
    {
      "name": "2 tablespoons honey or brown sugar",
      "amount": "tbsp"
    },
    {
      "name": "A handful of fresh herbs (parsley, cilantro) for garnish",
      "amount": ""
    },
    {
      "name": "Freshly ground black pepper to taste",
      "amount": ""
    }
  ],
  "instructions": [
    "Preheat oven to 400°F.",
    "Saute onion and garlic in oil until translucent.",
    "Add rice, cumin, smoked paprika, salt, and Sriracha; stir well.",
    "Pour in water or broth and honey/sugar. Bring to a boil.",
    "Reduce heat to low, cover with lid, and bake for 20 minutes.",
    "Remove from oven, reduce heat to medium, and continue baking uncovered until liquid is absorbed (15-20 more mins).",
    "Garnish with fresh herbs and serve hot.",
    "Optional: Adjust seasoning with additional salt or pepper if needed."
