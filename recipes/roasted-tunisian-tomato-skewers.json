  "ingredients": [
    {
      "name": "grape tomatoes",
      "amount": "1 pint",
      "notes": "halved"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "fermented harissa",
      "amount": "2 tbsp"
    },
    {
      "name": "lemon juice",
      "amount": "2 tbsp"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the raclette-grill to 400 degrees Fahrenheit.",
    "Thread the halved grape tomatoes onto skewers.",
    "In a bowl, whisk together the olive oil, fermented harissa, lemon juice, garlic, salt, and black pepper.",
    "Brush the mixture onto the tomato skewers.",
    "Place the skewers on the raclette-grill and roast for 15 minutes.",
    "Flip the skewers and roast for an additional 10 minutes.",
    "Remove the skewers from the grill and sprinkle with chopped parsley.",
    "Serve the skewers hot and enjoy."
  ],
