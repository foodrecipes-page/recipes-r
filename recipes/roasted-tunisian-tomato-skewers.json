{
  "title": "Roasted Tunisian Tomato Skewers",
  "description": "A light and crispy Tunisian dish featuring roasted grape tomatoes, perfect for a snack or side dish. This recipe is ayurvedic-tamasic-friendly and features a ferment for added depth of flavor.",
  "cuisine": "Tunisian",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
