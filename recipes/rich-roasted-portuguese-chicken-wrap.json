{
  "title": "Rich Roasted Portuguese Chicken Wrap",
  "description": "A pungent and velvety Portuguese dish featuring bouquet garni and caramelized onions, wrapped in a corn husk for a paleo-friendly meal.",
  "cuisine": "Portuguese",
