      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "boneless and skinless"
    },
    {
      "name": "bouquet garni",
      "amount": "1 bundle",
      "notes": "including thyme, rosemary, and parsley"
    },
    {
      "name": "onions",
      "amount": "1 large",
      "notes": "thinly sliced"
    },
    {
