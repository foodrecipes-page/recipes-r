  "instructions": [
    "Heat oil in a large pan over medium heat.",
    "Add the bruised lemongrass and cook for 1 minute.",
    "Add the chopped onion and cook until softened.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the chicken and cook until browned.",
    "Add the curry powder and cook for 1 minute.",
    "Pour in the coconut milk and bring to a simmer.",
    "Add the fish sauce, salt, and pepper, and stir to combine.",
    "Reduce heat to low and cook, covered, for 20 minutes.",
    "Remove the lemongrass and serve hot."
  ],
