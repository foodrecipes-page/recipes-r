      "notes": "drained overnight"
    },
    {
      "name": "Christmas pudding",
      "amount": "1/2 cup",
      "notes": "crumbled"
    },
    {
      "name": "fried rice",
      "amount": "1/2 cup",
      "notes": "cooled"
    },
    {
      "name": "khao khuah powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "pistachios",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "rose water",
      "amount": "1 teaspoon"
    },
    {
      "name": "orange blossom water",
      "amount": "1 teaspoon"
    },
    {
      "name": "honey",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "In a large bowl, combine the labneh cheese, crumbled Christmas pudding, and cooled fried rice",
    "In a small bowl, mix the khao khuah powder, chopped pistachios, rose water, and orange blossom water",
    "Add the dry mixture to the labneh mixture and stir until well combined",
    "Cover the bowl with plastic wrap and refrigerate for at least 2 hours",
    "Just before serving, drizzle the honey over the top of the labneh mixture",
    "Garnish with additional chopped pistachios if desired",
    "Serve chilled and enjoy",
    "Refrigerate any leftovers for up to 3 days"
  ],
