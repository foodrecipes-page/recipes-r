      "name": "Rice Krispies",
      "amount": "2 cups",
      "notes": "crushed into fine crumbs"
    },
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "diced into small pieces"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "finely chopped"
    },
    {
      "name": "mushroom",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups",
      "notes": "low-sodium"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "dried thyme",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the sous-vide machine to 180°F.",
    "In a bowl, mix together the crushed Rice Krispies, diced chicken, chopped onion, sliced mushroom, and dried thyme.",
    "In a separate bowl, whisk together the chicken broth and olive oil.",
    "Add the wet ingredients to the dry ingredients and stir until well combined.",
    "Season with salt and black pepper to taste.",
    "Transfer the mixture to a sous-vide bag and seal.",
    "Cook the pilaf in the sous-vide machine for 30 minutes.",
    "Remove the pilaf from the bag and fluff with a fork.",
    "Serve hot and enjoy!",
    "Garnish with fresh herbs, if desired."
  ],
