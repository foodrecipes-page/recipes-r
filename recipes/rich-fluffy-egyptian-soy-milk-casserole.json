      "amount": "2 cups",
      "notes": "unsweetened"
    },
    {
      "name": "all purpose flour",
      "amount": "1 cup"
    },
    {
      "name": "butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "sour cream",
      "amount": "1 cup"
    },
    {
      "name": "eggs",
      "amount": "2 large"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "dried thyme",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together the soy milk, flour, and melted butter.",
    "Add the sour cream, eggs, salt, black pepper, and dried thyme to the bowl and mix until smooth.",
    "Pour the mixture into a 9x13 inch baking dish.",
    "Bake the casserole for 35 minutes or until the edges are golden brown.",
    "Remove the casserole from the oven and let it cool for 10 minutes.",
    "Serve the casserole warm and enjoy.",
    "Garnish with fresh herbs if desired.",
    "Refrigerate any leftovers for up to 3 days."
  ],
