      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "fresh parsley",
      "amount": "2 tbsp",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a clay pot over medium heat.",
    "Add the smoked paprika, cumin, and coriander and sauté for 30 seconds until fragrant.",
    "Place the sliced radish in the pot and stir to coat with spices.",
    "Pour in the water, add salt, pepper, and lemon juice, then bring to a gentle simmer.",
    "Cover the pot, reduce heat to low, and let the radish cook for 25 minutes until tender.",
    "Stir occasionally to prevent sticking and maintain a silky texture.",
    "Once cooked, taste and adjust seasoning if needed.",
    "Garnish with chopped parsley before serving."
  ],
