{
  "title": "Robust Juicy Portuguese Chicken Skewers",
  "description": "A malty and juicy post-workout Portuguese dish featuring sake and infuse-oil, with anti-inflammatory friendly ingredients to aid in recovery.",
  "cuisine": "Portuguese",
  "diet": [
    "gluten-free",
    "dairy-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "sake",
      "amount": "1/4 cup"
    },
    {
      "name": "infuse-oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "turmeric",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together sake, infuse-oil, garlic, ginger, turmeric, paprika, salt, and black pepper.",
    "Add the chicken to the bowl and toss to coat with the marinade.",
    "Thread the chicken onto skewers, leaving a small space between each piece.",
    "Grill the skewers for 10-12 minutes, turning occasionally, until the chicken is cooked through.",
    "Brush the chicken with lemon juice during the last 2 minutes of grilling.",
    "Remove the skewers from the grill and let rest for 5 minutes.",
    "Serve the skewers hot, garnished with fresh parsley or cilantro if desired."
  ],
